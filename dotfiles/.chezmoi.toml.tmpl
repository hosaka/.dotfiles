{{- $work := promptBoolOnce . "work" "Is this a work computer? (y/N)" -}}
{{- $development := promptBoolOnce . "development" "Do you do development on this computer? (y/N)" -}}

encryption = "age"
[age]
  identity  = "{{ .chezmoi.homeDir }}/.config/sops/age/keys.txt"
  recipient = "age1yubikey1qv9d7qpcpstrf6mafkxekfwjcp29984saucq76gfyewz5ytl70eevwgwkqj"

[data]
  work        = {{ $work }}
  development = {{ $development }}

  xdgCacheDir       = "{{ .chezmoi.homeDir }}/.cache"
  xdgConfigDir      = "{{ .chezmoi.homeDir }}/.config"
  xdgDataDir        = "{{ .chezmoi.homeDir }}/.local/share"
  xdgStateDir       = "{{ .chezmoi.homeDir }}/.local/state"
